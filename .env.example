# Copy to .env.local and fill in from your Supabase project settings.
# Settings → API → Project URL and Project API keys (anon/public).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Public VAPID key for Web Push notifications (Feature 9). Public — safe to ship.
# The matching private key is a Supabase function secret, never in the client.
# Optional: the notifications opt-in stays hidden until this is set.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
